{
  "name": "alien-box-music-interface",
  "private": true,
  "version": "1.0.0",
  "description": "Alien Box: The Universal Musical Bible",
  "author": {
    "name": "CHUS BZN",
    "email": "dev@produktes.code"
  },
  "main": "main.cjs",
  "scripts": {
    "pack:win": "electron-builder --win",
    "pack:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.produktes.alienbox",
    "productName": "Alien Box",
    "files": [
      "main.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo"
    },
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "dist",
        "to": "backend"
      },
      {
        "from": "splash_screen_organic_v3_final",
        "to": "splash_screen_organic_v3_final"
      }
    ]
  },
  "dependencies": {
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
